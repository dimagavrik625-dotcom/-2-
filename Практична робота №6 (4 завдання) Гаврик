public class Task4 {
    public static void main(String[] args) {

        int count = 0;

        for (int i = 0; i <= 90; i++) {
            double sin = Math.sin(Math.toRadians(i));

            System.out.printf("%8.4f", sin);
            count++;

            if (count == 10) {
                System.out.println();
                count = 0;
            }
        }
    }
}
